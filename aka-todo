<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Напоминалка ToDo</title>
    <style>
        body { font-family: Arial; padding: 20px; background: #f4f4f4; }
        .container { max-width: 700px; margin: 0 auto; background: white; padding: 20px; border-radius: 12px; }
        .task { padding: 10px; margin: 6px 0; border-radius: 6px; display: flex; justify-content: space-between; }
        .past { background: #f8d7da; color: #721c24; border-left: 5px solid #dc3545; }
        .current { background: #fff3cd; color: #856404; border-left: 5px solid #ffc107; }
        .future { background: #d4edda; color: #155724; border-left: 5px solid #28a745; }
        .add-form { margin-top: 20px; display: flex; gap: 10px; flex-wrap: wrap; }
        .add-form input, .add-form select, .add-form button { padding: 8px; border-radius: 6px; border: 1px solid #ccc; }
        .add-form button { background: #007bff; color: white; border: none; cursor: pointer; }
        .add-form button:hover { background: #0056b3; }
        .task-id { font-weight: bold; margin-right: 15px; color: #333; }
        .task-date { color: #555; font-size: 0.9em; }
    </style>
</head>
<body>
<div class="container">
    <h2>📋 Напоминалка ToDo</h2>
    <div id="task-list"></div>

    <div class="add-form">
        <input type="text" id="new-title" placeholder="Название задачи" />
        <select id="new-type">
            <option value="past">Прошлое</option>
            <option value="current" selected>Текущее</option>
            <option value="future">Будущее</option>
        </select>
        <input type="date" id="new-date" />
        <button onclick="addTask()">➕ Добавить</button>
    </div>
</div>

<script>
    async function loadTasks() {
        const res = await fetch('/api/tasks');
        const tasks = await res.json();
        const list = document.getElementById('task-list');
        list.innerHTML = '';
        tasks.forEach(t => {
            const div = document.createElement('div');
            div.className = `task ${t.type}`;
            div.innerHTML = `
                <span><span class="task-id">#${t.id}</span> ${t.title}</span>
                <span class="task-date">${t.date}</span>
            `;
            list.appendChild(div);
        });
    }

    async function addTask() {
        const title = document.getElementById('new-title').value.trim();
        const type = document.getElementById('new-type').value;
        const date = document.getElementById('new-date').value;
        if (!title || !date) { alert('Заполните название и дату'); return; }
        const res = await fetch('/api/tasks', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title, type, date })
        });
        if (res.ok) {
            document.getElementById('new-title').value = '';
            document.getElementById('new-date').value = '';
            loadTasks();
        }
    }

    loadTasks();
</script>
</body>
</html>
